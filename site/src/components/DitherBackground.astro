<div class="dither-background" aria-hidden="true">
  <canvas class="dither-canvas" data-dither-canvas></canvas>
  <div class="dither-vignette"></div>
</div>

<style>
  .dither-background {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
    background: #030405;
  }

  .dither-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    opacity: 0.98;
  }

  .dither-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 52% 46%, rgba(6, 7, 9, 0) 0%, rgba(6, 7, 9, 0.04) 42%, rgba(3, 4, 5, 0.18) 76%, rgba(2, 3, 4, 0.4) 100%),
      linear-gradient(180deg, rgba(3, 4, 5, 0.03) 0%, rgba(3, 4, 5, 0.1) 100%);
  }
</style>

<script is:inline>
  (() => {
    const canvas = document.querySelector("[data-dither-canvas]");
    if (!(canvas instanceof HTMLCanvasElement)) return;

    const context = canvas.getContext("2d", { alpha: false });
    if (!context) return;
    const bufferCanvas = document.createElement("canvas");
    const bufferContext = bufferCanvas.getContext("2d", { alpha: false });
    if (!bufferContext) return;

    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const bayer4 = [
      [0, 8, 2, 10],
      [12, 4, 14, 6],
      [3, 11, 1, 9],
      [15, 7, 13, 5],
    ];
    const palette = [
      [3, 4, 5],
      [10, 12, 15],
      [18, 21, 25],
      [31, 35, 40],
      [52, 58, 66],
      [164, 171, 180],
    ];

    let animationFrame = 0;
    let width = 0;
    let height = 0;
    let cellSize = 9;
    let columns = 0;
    let rows = 0;
    let imageData = null;
    let data = null;
    let lastFrameMs = 0;
    const targetFrameMs = 1000 / 12;

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function smoothstep(edge0, edge1, x) {
      const t = clamp((x - edge0) / (edge1 - edge0), 0, 1);
      return t * t * (3 - 2 * t);
    }

    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      cellSize = width < 720 ? 2 : 2.5;
      columns = Math.ceil(width / cellSize);
      rows = Math.ceil(height / cellSize);

      canvas.width = width;
      canvas.height = height;
      canvas.style.width = `${width}px`;
      canvas.style.height = `${height}px`;
      context.setTransform(1, 0, 0, 1, 0, 0);
      context.imageSmoothingEnabled = false;

      bufferCanvas.width = columns;
      bufferCanvas.height = rows;
      bufferContext.imageSmoothingEnabled = false;
      imageData = bufferContext.createImageData(columns, rows);
      data = imageData.data;
    }

    function fieldAt(nx, ny, time) {
      const driftX = time * 0.009;
      const driftY = time * 0.0056;

      const bandA = Math.sin((ny + driftY) * 9.6 + Math.sin((nx + driftX * 0.85) * 2.7) * 1.25);
      const bandB = Math.cos((ny - driftY * 0.9) * 7.3 - Math.cos((nx - driftX * 0.55) * 3.5) * 1.05);
      const bandC = Math.sin((ny * 6.4 + nx * 1.55) + time * 0.0064);
      const bandD = Math.cos((ny * 5.3 - nx * 1.1) - time * 0.0052);
      const longWave = Math.sin((nx * 1.4 + ny * 2.2) + time * 0.0038);
      const crossWave = Math.cos((nx * 2.8 - ny * 1.7) - time * 0.0028);

      const horizontalEnvelope = smoothstep(0.02, 0.18, ny) * (1 - smoothstep(0.84, 0.99, ny));
      const centerLift = smoothstep(0.02, 0.95, 1 - Math.abs(nx - 0.56) * 1.18) * 0.06;
      const edgeFalloff = smoothstep(0.01, 0.9, 1 - Math.abs(nx - 0.5) * 1.56) * 0.04;

      const field =
        0.18 +
        horizontalEnvelope * 0.16 +
        bandA * 0.12 +
        bandB * 0.1 +
        bandC * 0.08 +
        bandD * 0.06 +
        longWave * 0.05 +
        crossWave * 0.03 +
        centerLift +
        edgeFalloff;

      const distanceX = (nx - 0.5) / 1.18;
      const distanceY = (ny - 0.5) / 1.12;
      const vignette = clamp(1 - Math.sqrt(distanceX * distanceX + distanceY * distanceY), 0, 1);

      const value = field + smoothstep(0.02, 0.98, vignette) * 0.08;
      return clamp(value, 0, 1);
    }

    function toneIndex(field, x, y) {
      const threshold = (bayer4[y % 4][x % 4] + 0.5) / 16 - 0.5;
      const quantized = field * 3.3 + threshold * 0.5;
      let index = Math.round(quantized);
      index = clamp(index, 0, palette.length - 2);

      if (field > 0.975 && ((x + y) % 11 === 0 || bayer4[y % 4][x % 4] === 0)) {
        index = palette.length - 1;
      }

      return index;
    }

    function render(timeMs) {
      if (!reduceMotion.matches && timeMs - lastFrameMs < targetFrameMs) {
        animationFrame = window.requestAnimationFrame(render);
        return;
      }

      lastFrameMs = timeMs;
      const time = timeMs * 0.001;

      for (let y = 0; y < rows; y += 1) {
        for (let x = 0; x < columns; x += 1) {
          const nx = columns <= 1 ? 0 : x / (columns - 1);
          const ny = rows <= 1 ? 0 : y / (rows - 1);
          const field = fieldAt(nx, ny, time);
          const tone = palette[toneIndex(field, x, y)];
          const offset = (y * columns + x) * 4;
          data[offset] = tone[0];
          data[offset + 1] = tone[1];
          data[offset + 2] = tone[2];
          data[offset + 3] = 255;
        }
      }

      bufferContext.putImageData(imageData, 0, 0);
      context.clearRect(0, 0, width, height);
      context.drawImage(bufferCanvas, 0, 0, width, height);

      if (!reduceMotion.matches) {
        animationFrame = window.requestAnimationFrame(render);
      }
    }

    function restart() {
      window.cancelAnimationFrame(animationFrame);
      resize();
      render(performance.now());
    }

    const handleMotionChange = () => restart();
    const handleResize = () => restart();

    resize();
    render(performance.now());

    window.addEventListener("resize", handleResize, { passive: true });
    reduceMotion.addEventListener("change", handleMotionChange);
  })();
</script>
