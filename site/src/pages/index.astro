---
import Layout from "../layouts/Layout.astro";

const APP_VERSION = "1.0.0"; // ← release script updates this line on each release
const DMG_URL = `https://github.com/c0/quixote-swift/releases/download/v${APP_VERSION}/QuixoteSwift-${APP_VERSION}.dmg`;
const GITHUB_URL = "https://github.com/c0/quixote-swift";
---

<Layout>
  <main>
    <section class="hero">
      <h1>Quixote Swift</h1>
      <p class="tagline">Your tagline here.</p>
      <div class="buttons">
        <a href={DMG_URL} class="btn primary">
          <svg width="16" height="16" viewBox="0 0 814 1000" fill="currentColor">
            <path d="M788.1 340.9c-5.8 4.5-108.2 62.2-108.2 190.5 0 148.4 130.3 200.9 134.2 202.2-.6 3.2-20.7 71.9-68.7 141.9-42.8 61.6-87.5 123.1-155.5 123.1s-85.5-39.5-164-39.5c-76.5 0-103.7 40.8-165.9 40.8s-105.6-57.8-155.5-127.4c-58.5-81.7-105.3-209-105.3-329.1 0-193.1 125.6-295.7 249.2-295.7 65.7 0 120.5 43.2 161.7 43.2 39.2 0 100.4-45.8 174.5-45.8 28.2 0 129.3 2.6 196.3 99.8zm-135.5-183.1c31.1-36.9 53.1-88.1 53.1-139.3 0-7.1-.6-14.3-1.9-20.1-50.6 1.9-110.8 33.7-147.1 75.8-28.2 32.4-55.1 83.6-55.1 135.5 0 7.8 1.3 15.6 1.9 18.1 3.2.6 8.4 1.3 13.6 1.3 45.4 0 102.5-30.4 135.5-71.3z" />
          </svg>
          Download for macOS
        </a>
        <a href={GITHUB_URL} class="btn secondary">GitHub</a>
      </div>
      <p class="meta">{APP_VERSION} &middot; macOS Sonoma or later &middot; Free</p>
    </section>

    <footer>
      <p>&copy; 2026 &middot; <a href={GITHUB_URL}>Open source</a> under MIT</p>
    </footer>
  </main>
</Layout>

<style>
  main {
    max-width: 640px;
    margin: 0 auto;
    padding: 100px 24px 60px;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  h1 {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .tagline {
    font-size: 1.2rem;
    color: var(--text-secondary);
    max-width: 480px;
  }

  .buttons {
    display: flex;
    gap: 10px;
    margin-top: 8px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 22px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .btn:hover {
    opacity: 0.8;
    text-decoration: none;
  }

  .btn.primary {
    background: var(--accent);
    color: #fff;
  }

  .btn.secondary {
    background: var(--border);
    color: var(--text);
  }

  .meta {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    margin-top: 4px;
  }

  footer {
    text-align: center;
    font-size: 0.82rem;
    color: var(--text-tertiary);
  }
</style>
