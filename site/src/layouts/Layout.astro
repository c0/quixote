---
import DitherBackground from "../components/DitherBackground.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Data Quixote - Test LLM prompts on local data",
  description = "Test your LLM prompts on local data. Iterate, compare model output, and export results from a native macOS app.",
  image = "og-image.png",
} = Astro.props;
const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const siteBase = Astro.site?.toString();
const pageUrl = siteBase
  ? new URL(Astro.url.pathname, siteBase).toString()
  : Astro.url.pathname;
const imageUrl = siteBase
  ? new URL(`${assetBase}${image}`.replace(/^\//, ""), siteBase).toString()
  : `${assetBase}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/png" href={`${assetBase}favicon.png`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Data Quixote logo" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <style>
      :root {
        --bg: #030405;
        --panel: rgba(10, 12, 16, 0.72);
        --panel-strong: rgba(14, 17, 22, 0.86);
        --text: #f3f5f8;
        --text-secondary: #aeb6c2;
        --text-tertiary: #727b87;
        --accent: #d9e0ea;
        --accent-strong: #f9fbff;
        --border: rgba(255, 255, 255, 0.1);
        --shadow: 0 24px 80px rgba(0, 0, 0, 0.45);
      }

      * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        background: var(--bg);
        color: var(--text);
        font-family: "SF Pro Display", "SF Pro Text", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        font-size: 16px;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        color-scheme: dark;
        width: 100%;
        overflow-x: clip;
      }

      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        position: relative;
        width: 100%;
        overflow-x: clip;
      }

      .site-frame {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        width: 100%;
        overflow-x: clip;
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <DitherBackground />
    <div class="site-frame">
      <slot />
    </div>
  </body>
</html>
