# Apple Developer credentials for release signing and notarization
APPLE_TEAM_ID=
APPLE_ID=
SIGNING_IDENTITY_NAME=
# Generate at appleid.apple.com → Sign-In and Security → App-Specific Passwords
APPLE_APP_SPECIFIC_PASSWORD=
# Absolute path to your Sparkle private key file (base64-encoded ed25519 seed)
SPARKLE_PRIVATE_KEY_PATH=/tmp/quixote_sparkle_private_key
